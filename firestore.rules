rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Lê dados de users/{uid}. Se o doc ainda não existir (primeiro login),
    // get() retorna null e comparações falham normalmente sem lançar exceção.
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getRole()     { return userData().role; }
    function getUnitId()   { return userData().unitId; }
    function getChurchId() { return userData().churchId; }

    // ── Funções de papel ──────────────────────────────────────────────────────

    function isAdmin() {
      return isSignedIn() && getRole() == 'Administrador';
    }

    // Editores de unidade: podem criar/editar chamada e metas da própria unidade
    function isUnitEditor() {
      return isSignedIn() && (
        getRole() == 'Professor ES' ||
        getRole() == 'Secretário de Unidade'
      );
    }

    // Staff de igreja: visualizam e emitem relatórios
    function isChurchStaff() {
      return isSignedIn() && (
        getRole() == 'Ancião' ||
        getRole() == 'Diretor ES' ||
        getRole() == 'Secretário ES'
      );
    }

    // Pastor: visualiza o distrito
    function isPastor() {
      return isSignedIn() && getRole() == 'Pastor';
    }

    // Coordenadores de associação, união e divisão: somente leitura
    function isCoord() {
      return isSignedIn() && (
        getRole() == 'Coord. Associação' ||
        getRole() == 'Coord. União'      ||
        getRole() == 'Coord. Divisão'
      );
    }

    // Qualquer papel com acesso ao sistema (exceto Aluno)
    function isStaff() {
      return isAdmin() || isUnitEditor() || isChurchStaff() || isPastor() || isCoord();
    }

    // ── users/{uid} ───────────────────────────────────────────────────────────
    // AppContext sincroniza users/{uid} a partir de members após login.
    // write irrestrito do próprio doc resolve o bootstrap (primeiro login).
    // Administrador pode atualizar ou deletar qualquer doc de usuário.
    match /users/{uid} {
      allow read:   if isSignedIn() && request.auth.uid == uid;
      allow write:  if isSignedIn() && request.auth.uid == uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── members ───────────────────────────────────────────────────────────────
    // Staff lê todos; membros comuns lêem apenas o próprio registro (bootstrap).
    match /members/{memberId} {
      allow read: if isStaff()
                  || (isSignedIn() && resource.data.email == request.auth.token.email);

      allow create: if isAdmin();

      allow update: if isAdmin()
                    || (isChurchStaff()
                        && resource.data.churchId != null
                        && resource.data.churchId == getChurchId())
                    || (isUnitEditor()
                        && resource.data.unitId != null
                        && resource.data.unitId == getUnitId());

      allow delete: if isAdmin();
    }

    // ── hierarchy ─────────────────────────────────────────────────────────────
    match /hierarchy/{docId} {
      allow read:  if isStaff();
      allow write: if isAdmin();
    }

    // ── rollCalls ─────────────────────────────────────────────────────────────
    // Editores de unidade lêem/escrevem apenas a própria unidade.
    // Church staff, Pastor e Coords têm leitura ampla (relatórios).
    match /rollCalls/{rollCallId} {
      allow read: if isAdmin() || isChurchStaff() || isPastor() || isCoord()
                  || (isUnitEditor()
                      && resource.data.unitId != null
                      && resource.data.unitId == getUnitId());

      allow create: if isAdmin()
                    || (isUnitEditor()
                        && request.resource.data.unitId != null
                        && request.resource.data.unitId == getUnitId());

      allow update: if isAdmin()
                    || (isUnitEditor()
                        && resource.data.unitId != null
                        && resource.data.unitId == getUnitId());

      allow delete: if isAdmin();
    }

    // ── quarters ──────────────────────────────────────────────────────────────
    match /quarters/{quarterId} {
      allow read:  if isStaff();
      allow write: if isAdmin();
    }

    // ── scoreWeights ──────────────────────────────────────────────────────────
    match /scoreWeights/{docId} {
      allow read:  if isStaff();
      allow write: if isAdmin();
    }

    // ── goals ─────────────────────────────────────────────────────────────────
    // Documento ID: {quarterId}_{unitId}
    // Editores de unidade lêem/escrevem apenas a meta da própria unidade.
    // Church staff, Pastor e Coords têm leitura ampla.
    match /goals/{goalId} {
      allow read: if isAdmin() || isChurchStaff() || isPastor() || isCoord()
                  || (isUnitEditor() && resource.data.unitId == getUnitId());

      allow create: if isAdmin()
                    || (isUnitEditor()
                        && request.resource.data.unitId != null
                        && request.resource.data.unitId == getUnitId());

      allow update: if isAdmin()
                    || (isUnitEditor() && resource.data.unitId == getUnitId());

      allow delete: if isAdmin();
    }
  }
}
